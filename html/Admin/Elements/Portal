<%init>
# All stats via direct SQL — RT ORM queries (especially LimitToPrivileged)
# generate complex joins that exceed RT's DatabaseQueryTimeout.
my $dbh = $RT::Handle->dbh;

# Queues
my ($queues_total)  = $dbh->selectrow_array("SELECT COUNT(*) FROM Queues WHERE id > 0");
my ($queues_active) = $dbh->selectrow_array("SELECT COUNT(*) FROM Queues WHERE id > 0 AND Disabled = 0");

# Custom Fields
my ($cfs_total)  = $dbh->selectrow_array("SELECT COUNT(*) FROM CustomFields");
my ($cfs_active) = $dbh->selectrow_array("SELECT COUNT(*) FROM CustomFields WHERE Disabled = 0");

# User-defined groups only (Domain = 'UserDefined')
my ($groups_count) = $dbh->selectrow_array("SELECT COUNT(*) FROM Groups WHERE Domain = 'UserDefined'");

# Users — Disabled lives in Principals (1:1 with Users by id).
# ids 1 (RT_System) and 2 (Nobody) are RT internal pseudo-users.
my ($users_privileged) = $dbh->selectrow_array(
    "SELECT COUNT(DISTINCT u.id) FROM Users u
     JOIN CachedGroupMembers cgm ON cgm.MemberId = u.id
     JOIN Principals p ON p.id = u.id
     WHERE cgm.ImmediateParentId = 4 AND p.Disabled = 0 AND u.id > 2"
);
my ($users_unprivileged) = $dbh->selectrow_array(
    "SELECT COUNT(DISTINCT u.id) FROM Users u
     JOIN CachedGroupMembers cgm ON cgm.MemberId = u.id
     JOIN Principals p ON p.id = u.id
     WHERE cgm.ImmediateParentId = 5 AND p.Disabled = 0 AND u.id > 2"
);
my ($users_disabled) = $dbh->selectrow_array(
    "SELECT COUNT(*) FROM Principals WHERE Disabled = 1 AND PrincipalType = 'User' AND id > 2"
);

# Tickets — exclude id <= 0 (RT internal pseudo-tickets)
my %ticket_counts;

# Total (all non-deleted)
($ticket_counts{total}) = $dbh->selectrow_array(
    "SELECT COUNT(*) FROM Tickets WHERE id > 0 AND Status != 'deleted'"
);

# By status (including deleted)
my $rows = $dbh->selectall_arrayref(
    "SELECT Status, COUNT(*) FROM Tickets WHERE id > 0 GROUP BY Status"
);
my %by_status;
for my $row (@$rows) {
    $by_status{ $row->[0] } = $row->[1];
}

$ticket_counts{new}     = $by_status{new} // 0;
$ticket_counts{deleted} = $by_status{deleted} // 0;

# resolved/rejected: all "done" statuses
my @done_statuses = qw(resolved rejected done ClosedByHousekeeping on_hold cancelled);
$ticket_counts{resolved} = 0;
$ticket_counts{resolved} += ($by_status{$_} // 0) for @done_statuses;

# active: everything that's not new, not done, not deleted
$ticket_counts{active} = 0;
for my $status (keys %by_status) {
    next if $status eq 'new';
    next if $status eq 'deleted';
    next if grep { $_ eq $status } @done_statuses;
    $ticket_counts{active} += $by_status{$status};
}
</%init>
<&| /Widgets/TitleBox, title => loc('RT Internals') &>
<div class="admin-dashboard-stats">

  <div class="stats-section">
    <h4><% loc('Configuration') %></h4>
    <table class="stats-table">
      <tr>
        <td class="stat-label"><% loc('Queues') %></td>
        <td class="stat-value"><% $queues_active %></td>
        <td class="stat-sub">/ <% $queues_total %></td>
      </tr>
      <tr>
        <td class="stat-label"><% loc('Custom Fields') %></td>
        <td class="stat-value"><% $cfs_active %></td>
        <td class="stat-sub">/ <% $cfs_total %></td>
      </tr>
      <tr>
        <td class="stat-label"><% loc('Groups') %></td>
        <td class="stat-value"><% $groups_count %></td>
        <td class="stat-sub">&nbsp;</td>
      </tr>
    </table>
  </div>

  <div class="stats-section">
    <h4><% loc('Users') %></h4>
    <table class="stats-table">
      <tr>
        <td class="stat-label"><% loc('Privileged') %></td>
        <td class="stat-value"><% $users_privileged %></td>
        <td class="stat-sub">&nbsp;</td>
      </tr>
      <tr>
        <td class="stat-label"><% loc('Unprivileged') %></td>
        <td class="stat-value"><% $users_unprivileged %></td>
        <td class="stat-sub">&nbsp;</td>
      </tr>
      <tr>
        <td class="stat-label"><% loc('Disabled') %></td>
        <td class="stat-value stat-muted"><% $users_disabled %></td>
        <td class="stat-sub">&nbsp;</td>
      </tr>
    </table>
  </div>

  <div class="stats-section">
    <h4><% loc('Tickets') %></h4>
    <table class="stats-table">
      <tr>
        <td class="stat-label"><% loc('Total') %></td>
        <td class="stat-value"><% $ticket_counts{total} %></td>
        <td class="stat-sub">&nbsp;</td>
      </tr>
      <tr>
        <td class="stat-label"><% loc('New') %></td>
        <td class="stat-value stat-new"><% $ticket_counts{new} %></td>
        <td class="stat-sub">&nbsp;</td>
      </tr>
      <tr>
        <td class="stat-label"><% loc('Active') %></td>
        <td class="stat-value stat-active"><% $ticket_counts{active} %></td>
        <td class="stat-sub">&nbsp;</td>
      </tr>
      <tr>
        <td class="stat-label"><% loc('Resolved') %></td>
        <td class="stat-value stat-resolved"><% $ticket_counts{resolved} %></td>
        <td class="stat-sub">&nbsp;</td>
      </tr>
      <tr>
        <td class="stat-label"><% loc('Deleted') %></td>
        <td class="stat-value stat-muted"><% $ticket_counts{deleted} %></td>
        <td class="stat-sub">&nbsp;</td>
      </tr>
    </table>
  </div>

</div>
</&>

<style>
.admin-dashboard-stats {
    font-size: 0.9em;
}
.stats-section {
    margin-bottom: 1em;
}
.stats-section h4 {
    margin: 0 0 0.3em 0;
    font-size: 0.85em;
    text-transform: uppercase;
    color: #888;
    letter-spacing: 0.05em;
    border-bottom: 1px solid #e0e0e0;
    padding-bottom: 0.2em;
}
.stats-table {
    width: 100%;
    border-collapse: collapse;
}
.stats-table tr:hover {
    background: rgba(0,0,0,0.03);
}
.stat-label {
    padding: 0.15em 0.5em 0.15em 0;
    color: #555;
    width: 55%;
}
.stat-value {
    padding: 0.15em 0.3em;
    font-weight: bold;
    text-align: right;
    width: 20%;
}
.stat-sub {
    padding: 0.15em 0 0.15em 0.3em;
    color: #999;
    font-size: 0.85em;
    width: 25%;
}
.stat-new    { color: #d97706; }
.stat-active { color: #2563eb; }
.stat-resolved { color: #16a34a; }
.stat-muted  { color: #9ca3af; }
</style>

