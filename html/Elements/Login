}

.rd-login-brand .rd-brand-title {
    color: #fff;
}

.rd-login-brand .rd-brand-instance {
    color: rgba(255,255,255,0.6);
    margin-bottom: 0.3rem;
}

.rd-brand-sub {
    font-size: 0.88rem;
    color: rgba(255,255,255,0.7) !important;
    text-align: center;
    line-height: 1.5;
    margin-bottom: 0;
