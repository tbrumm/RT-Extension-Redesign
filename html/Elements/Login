<%init>
our ($login_stats_cache, $login_stats_cache_time);
my $CACHE_TTL = 6 * 3600;

if (!$login_stats_cache || (time() - ($login_stats_cache_time // 0)) > $CACHE_TTL) {
    my $su = RT->SystemUser;

    my $pu = RT::Users->new($su); $pu->LimitToPrivileged;
    my $uu = RT::Users->new($su); $uu->LimitToUnprivileged;
    my $grp = RT::Groups->new($su); $grp->LimitToUserDefinedGroups;
    my $q   = RT::Queues->new($su); $q->UnLimit;
    my $t   = RT::Tickets->new($su); $t->UnLimit;
    my $txn = RT::Transactions->new($su); $txn->UnLimit;

    my ($ac, $artc) = (0, 0);
    eval { my $a = RT::Assets->new($su); $a->UnLimit; $ac = $a->Count; };
    eval { my $a = RT::Articles->new($su); $a->UnLimit; $artc = $a->Count; };

    $login_stats_cache = {
        priv     => $pu->Count,
        unpriv   => $uu->Count,
        groups   => $grp->Count,
        queues   => $q->Count,
        tickets  => $t->Count,
        txns     => $txn->Count,
        assets   => $ac,
        articles => $artc,
    };
    $login_stats_cache_time = time();
}

my ($priv_count, $unpriv_count, $grp_count, $q_count,
    $t_count, $txn_count, $asset_count, $article_count) =
    @{$login_stats_cache}{qw(priv unpriv groups queues tickets txns assets articles)};

my $fmt = sub {
    my $s = reverse sprintf('%d', int($_[0]));
    $s =~ s/(\d{3})(?=\d)/$1./g;
    return scalar reverse $s;
};

</%init>

<%ARGS>
$next    => ''
$user    => ""
$actions => undef
</%ARGS>
