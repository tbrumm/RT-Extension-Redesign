<style>
/* ── RT-Extension-Redesign: Login ─────────────────────────── */

html:has(#body.login-body),
body:has(#body.login-body) { overflow: hidden; height: 100vh; margin: 0; padding: 0; background: var(--bs-body-bg); }

html:has(#body.login-body) hr.clear { display: none; }

#body.login-body {
    padding: 0;
    display: flex;
    flex-direction: column;
    height: 100vh;
    overflow: hidden;
}

.rd-login-outer {
    flex: 1;
    display: flex;
    overflow: hidden;
}

/* ── Left panel: brand + form ─────────────────────────── */

.rd-login-brand {
    flex: 0 0 25%;
    background: linear-gradient(150deg, #1E3875 0%, #2D4A8F 45%, #3254A0 100%);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2.5rem;
    padding: 2rem 2rem;
    position: relative;
    overflow: hidden;
    color: #fff;
}

.rd-brand-top {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    position: relative;
    z-index: 1;
}

.rd-login-card-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    position: relative;
    z-index: 1;
}

.rd-login-brand::before {
    content: '';
    position: absolute;
    top: -120px; right: -120px;
    width: 380px; height: 380px;
    border-radius: 50%;
    background: rgba(255,255,255,0.05);
    pointer-events: none;
}

.rd-login-brand::after {
    content: '';
    position: absolute;
    bottom: -100px; left: -100px;
    width: 300px; height: 300px;
    border-radius: 50%;
    background: rgba(255,255,255,0.04);
    pointer-events: none;
}

.rd-brand-monogram {
    font-size: 2.2rem;
    font-weight: 900;
    color: #fff;
    background: rgba(255,255,255,0.12);
    width: 80px; height: 80px;
    border-radius: 1.2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.2rem;
    letter-spacing: -0.04em;
    border: 1px solid rgba(255,255,255,0.2);
    position: relative;
    z-index: 1;
}

.rd-brand-title {
    font-size: 1.6rem;
    font-weight: 700;
    color: #fff;
    text-align: center;
    margin-bottom: 0.3rem;
    letter-spacing: -0.02em;
    position: relative;
    z-index: 1;
}

.rd-brand-instance {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.5);
    text-align: center;
    margin-bottom: 2rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    position: relative;
    z-index: 1;
}

/* ── Form card inside left panel ─────────────────────────── */

.rd-login-card {
    width: 100%;
    max-width: 360px;
    position: relative;
    z-index: 1;
}

.rd-login-card h2.rd-form-title {
    font-size: 1.2rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 0.2rem;
    letter-spacing: -0.01em;
}

.rd-login-card p.rd-form-sub {
    font-size: 0.82rem;
    color: rgba(255,255,255,0.5);
    margin-bottom: 1.4rem;
}

/* Labels */
.rd-login-card label,
.rd-login-card .labeled-value > label {
    color: rgba(255,255,255,0.8);
    font-size: 0.82rem;
    font-weight: 500;
}

/* Inputs */
.rd-login-card .form-control {
    background: rgba(255,255,255,0.08);
    border-color: rgba(255,255,255,0.18);
    color: #fff;
    border-radius: 0.5rem;
    transition: background 0.15s, border-color 0.15s, box-shadow 0.15s;
}

.rd-login-card .form-control:focus {
    background: rgba(255,255,255,0.14);
    border-color: rgba(255,255,255,0.45);
    box-shadow: 0 0 0 0.2rem rgba(255,255,255,0.1);
    color: #fff;
    outline: none;
}

.rd-login-card .form-control::placeholder {
    color: rgba(255,255,255,0.35);
}

/* Browser autofill override */
.rd-login-card .form-control:-webkit-autofill,
.rd-login-card .form-control:-webkit-autofill:focus {
    -webkit-box-shadow: 0 0 0 1000px #2a4590 inset !important;
    -webkit-text-fill-color: #fff !important;
    caret-color: #fff;
}

/* Submit button: white on dark */
.rd-login-card .rd-btn-submit {
    width: 100%;
    padding: 0.65rem 1.5rem;
    font-size: 0.95rem;
    font-weight: 600;
    border-radius: 0.5rem;
    background: #fff;
    border-color: #fff;
    color: #1E3875;
    transition: background 0.15s, box-shadow 0.15s;
}

.rd-login-card .rd-btn-submit:hover {
    background: rgba(255,255,255,0.88);
    border-color: rgba(255,255,255,0.88);
    color: #1E3875;
    box-shadow: 0 4px 14px rgba(0,0,0,0.3);
