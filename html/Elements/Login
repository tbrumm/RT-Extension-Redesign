/* Error/action messages */
.rd-login-card .titlebox-title { display: none; }
.rd-login-card .titlebox.error .titlebox-title { display: block; }
.rd-login-card .titlebox {
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.2);
    color: #fff;
    border-radius: 0.5rem;
    margin-bottom: 1rem;
    padding: 0.75rem 1rem;
}

/* LoginHelp / forgot password */
.rd-login-card a,
.rd-login-card .login-help {
    color: rgba(255,255,255,0.55);
    font-size: 0.82rem;
}
.rd-login-card a:hover { color: #fff; }

/* ── Left panel: brand header + plugin content ──────────────────── */

.rd-login-right {
