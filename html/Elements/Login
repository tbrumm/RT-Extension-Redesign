    z-index: 1;
}

/* ── Stats headline + widget ────────────────────────────────────── */

.rd-stats-headline {
    font-size: 0.92rem;
    color: var(--bs-secondary-color, #6c757d);
    text-align: center;
    max-width: 560px;
    margin: 1.2rem 0 0;
    line-height: 1.6;
}

.rd-stats-headline strong {
    color: var(--bs-body-color);
    font-weight: 600;
}

.rd-stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.55rem;
    margin-top: 1.4rem;
    width: 100%;
    max-width: 560px;
}

.rd-stat-card {
    background: var(--bs-tertiary-bg, rgba(0,0,0,0.04));
    border: 1px solid var(--bs-border-color);
    border-radius: 0.6rem;
