<%args>
$HasResults => undef
</%args>
<%init>
use RT::Extension::FeedWidget;
use JSON::PP ();

my $wid  = 'fw' . int(rand(999999));
my $user = $session{CurrentUser}->UserObj;

my $feeds = RT::Extension::FeedWidget->GetUserFeeds($user);

my $web_path   = RT->Config->Get('WebPath');
my $prefs_url  = $web_path . '/Prefs/AboutMe.html';
my $fetch_url  = $web_path . '/FeedWidget/Fetch.html';

my $_j = JSON::PP->new->ascii(1);
my $js_feeds     = $_j->encode($feeds);
my $js_fetch_url = $_j->encode($fetch_url);
my $js_prefs_url = $_j->encode($prefs_url);
</%init>

<&|/Widgets/TitleBox, title => loc('Feed Reader'), bodyclass => 'p-0' &>

<div class="fw-wrap" id="<% $wid %>">

% if (!@$feeds) {
  <div class="fw-empty">
    <span class="fw-big-icon">&#x1F4F0;</span>
    <p><% loc('No feeds configured yet.') %></p>
    <a href="<% $prefs_url | h %>" class="btn btn-sm btn-outline-primary">
      <% loc('Add feeds in preferences') %>
    </a>
  </div>
% } else {
  <div class="fw-loading">
    <div class="fw-spinner"></div>
    <small><% loc('Loading feeds...') %></small>
  </div>

  <div class="fw-error" hidden>
    <span class="fw-big-icon">&#x26A0;&#xFE0F;</span>
    <p class="fw-err-msg"></p>
    <button class="btn btn-sm btn-outline-secondary fw-retry-btn"><% loc('Retry') %></button>
  </div>

  <div class="fw-content" hidden>
    <div class="fw-tabs" id="<% $wid %>-tabs" role="tablist"></div>
    <div class="fw-panels" id="<% $wid %>-panels"></div>
    <div class="fw-footer">
      <a href="<% $prefs_url | h %>" class="fw-prefs-link">
        &#x2699;&#xFE0F; <% loc('Manage feeds') %>
      </a>
      <button class="fw-refresh-btn" title="<% loc('Refresh') | h %>">&#x21BB;</button>
    </div>
  </div>
% }

</div>

<style>
/* ---- FeedWidget -------------------------------------------- */
.fw-wrap {
  background: var(--bs-card-bg);
  border-radius: 0 0 6px 6px;
  display: flex;
  flex-direction: column;
  min-height: 120px;
}

/* Loading / error / empty states */
.fw-loading, .fw-error, .fw-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  gap: 0.4rem;
  padding: 1.2rem 1rem;
  flex: 1;
}

.fw-spinner {
  width: 20px; height: 20px;
  border: 3px solid rgba(0,0,0,0.1);
  border-top-color: var(--bs-primary);
  border-radius: 50%;
  animation: fw-spin 0.75s linear infinite;
}
[data-bs-theme=dark] .fw-spinner {
  border-color: rgba(255,255,255,0.12);
  border-top-color: var(--bs-primary);
}
@keyframes fw-spin { to { transform: rotate(360deg); } }

.fw-big-icon { font-size: 1.6rem; line-height: 1; }

.fw-empty p, .fw-error p {
  font-size: 0.82rem; color: var(--bs-secondary-color); margin: 0; max-width: 220px;
}

/* ---- Tabs -------------------------------------------------- */
.fw-tabs {
  display: flex;
  overflow-x: auto;
  scrollbar-width: none;
  border-bottom: 1px solid var(--bs-border-color);
  background: var(--bs-tertiary-bg);
  padding: 0 0.5rem;
  gap: 0;
  flex-shrink: 0;
}
.fw-tabs::-webkit-scrollbar { display: none; }

.fw-tab {
  padding: 0.4rem 0.75rem;
  font-size: 0.78rem;
  font-weight: 500;
  white-space: nowrap;
  cursor: pointer;
  border: none;
  background: none;
  color: var(--bs-secondary-color);
  border-bottom: 2px solid transparent;
  margin-bottom: -1px;
  transition: color 0.15s, border-color 0.15s;
  max-width: 120px;
  overflow: hidden;
  text-overflow: ellipsis;
}
.fw-tab:hover { color: var(--bs-body-color); }
.fw-tab.active {
  color: var(--bs-primary);
  border-bottom-color: var(--bs-primary);
  font-weight: 600;
}
.fw-tab .fw-tab-err {
  display: inline-block;
  width: 6px; height: 6px;
  background: var(--bs-danger);
  border-radius: 50%;
  margin-left: 4px;
  vertical-align: middle;
}

/* ---- Panels ------------------------------------------------ */
.fw-panels { flex: 1; overflow: hidden; }

.fw-panel { display: none; }
.fw-panel.active { display: block; }

.fw-panel-error {
  padding: 0.8rem 1rem;
  font-size: 0.8rem;
  color: var(--bs-danger);
  text-align: center;
}

/* ---- Item list --------------------------------------------- */
.fw-items {
  list-style: none;
  margin: 0;
  padding: 0;
  max-height: 320px;
  overflow-y: auto;
}

.fw-item {
  padding: 0.5rem 0.85rem;
  border-bottom: 1px solid var(--bs-border-color);
}
.fw-item:last-child { border-bottom: none; }

.fw-item-title {
  font-size: 0.82rem;
  font-weight: 500;
  color: var(--bs-body-color);
  text-decoration: none;
  display: block;
  line-height: 1.35;
}
.fw-item-title:hover { color: var(--bs-primary); text-decoration: underline; }

.fw-item-meta {
  font-size: 0.7rem;
  color: var(--bs-secondary-color);
  margin-top: 0.15rem;
}

.fw-item-summary {
  font-size: 0.75rem;
  color: var(--bs-secondary-color);
  margin-top: 0.2rem;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* ---- Footer ------------------------------------------------ */
.fw-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0.25rem 0.85rem 0.3rem;
  border-top: 1px solid var(--bs-border-color);
  background: var(--bs-tertiary-bg);
  border-radius: 0 0 6px 6px;
  flex-shrink: 0;
}

.fw-prefs-link {
  font-size: 0.7rem;
  color: var(--bs-secondary-color);
  text-decoration: none;
}
.fw-prefs-link:hover { color: var(--bs-primary); }

.fw-refresh-btn {
  background: none; border: none; padding: 0;
  cursor: pointer; font-size: 0.95rem; color: var(--bs-secondary-color); line-height: 1;
}
.fw-refresh-btn:hover { color: var(--bs-primary); }
</style>

% if (@$feeds) {
<script>
(function () {
  var ID       = '<% $wid | n %>';
  var FEEDS    = <% $js_feeds    | n %>;
  var FETCH    = <% $js_fetch_url | n %>;
  var FW_NO_ITEMS = <% loc('No items found.') |j %>;

  var wrap    = document.getElementById(ID);
  var sLoad   = wrap.querySelector('.fw-loading');
  var sErr    = wrap.querySelector('.fw-error');
  var sCont   = wrap.querySelector('.fw-content');
  var tabBar  = document.getElementById(ID + '-tabs');
  var panels  = document.getElementById(ID + '-panels');

  function showState(el) {
    [sLoad, sErr, sCont].forEach(function(e) { e.hidden = true; });
    el.hidden = false;
  }

  function escHtml(s) {
    return String(s)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function activateTab(idx) {
    var tabs = tabBar.querySelectorAll('.fw-tab');
    var panes = panels.querySelectorAll('.fw-panel');
    tabs.forEach(function(t, i) {
      t.classList.toggle('active', i === idx);
    });
    panes.forEach(function(p, i) {
      p.classList.toggle('active', i === idx);
    });
  }

  function buildTab(label, idx, hasError) {
    var btn = document.createElement('button');
    btn.className = 'fw-tab';
    btn.setAttribute('role', 'tab');
    btn.title = label;
    btn.textContent = label;
    if (hasError) {
      var dot = document.createElement('span');
      dot.className = 'fw-tab-err';
      btn.appendChild(dot);
    }
    btn.addEventListener('click', function() { activateTab(idx); });
    tabBar.appendChild(btn);
  }

  function buildPanel(feedData, feedCfg) {
    var panel = document.createElement('div');
    panel.className = 'fw-panel';

    if (feedData.error) {
      var errDiv = document.createElement('div');
      errDiv.className = 'fw-panel-error';
      errDiv.textContent = feedData.error;
      panel.appendChild(errDiv);
    } else {
      var ul = document.createElement('ul');
      ul.className = 'fw-items';
      var items = feedData.items || [];
      if (!items.length) {
        var li = document.createElement('li');
        li.className = 'fw-item';
        li.style.textAlign = 'center';
        li.style.color = 'var(--bs-secondary-color)';
        li.style.fontSize = '0.8rem';
        li.style.padding = '1rem';
        li.textContent = FW_NO_ITEMS;
        ul.appendChild(li);
      }
      items.forEach(function(item) {
        var li   = document.createElement('li');
        li.className = 'fw-item';

        var a = document.createElement('a');
        a.className = 'fw-item-title';
        a.href = item.link || '#';
        a.target = '_blank';
        a.rel = 'noopener noreferrer';
        a.textContent = item.title || '(no title)';
        li.appendChild(a);

        if (item.pubdate) {
          var meta = document.createElement('div');
          meta.className = 'fw-item-meta';
          meta.textContent = item.pubdate;
          li.appendChild(meta);
        }

        if (item.summary) {
          var sum = document.createElement('div');
          sum.className = 'fw-item-summary';
          sum.textContent = item.summary;
          li.appendChild(sum);
        }

        ul.appendChild(li);
      });
      panel.appendChild(ul);
    }

    panels.appendChild(panel);
    return panel;
  }

  function load() {
    showState(sLoad);
    tabBar.innerHTML = '';
    panels.innerHTML = '';

    var pending = FEEDS.length;
    var results = new Array(FEEDS.length);

    function done(idx, data) {
      results[idx] = data;
      pending--;
      if (pending === 0) { render(results); }
    }

    FEEDS.forEach(function(feed, idx) {
      var url = FETCH + '?url=' + encodeURIComponent(feed.url)
                      + '&max=' + encodeURIComponent(feed.max_items || 10);
      fetch(url, { credentials: 'same-origin' })
        .then(function(r) {
          if (!r.ok) throw new Error('HTTP ' + r.status);
          return r.json();
        })
        .then(function(data) { done(idx, data); })
        .catch(function(e) { done(idx, { error: e.message, items: [] }); });
    });
  }

  function render(results) {
    if (!results.length) { showState(sErr); return; }

    results.forEach(function(data, idx) {
      var cfg    = FEEDS[idx];
      var label  = data.feed_title || cfg.title || cfg.url;
      if (label.length > 20) label = label.substring(0, 18) + '\u2026';
      buildTab(label, idx, !!data.error);
      buildPanel(data, cfg);
    });

    activateTab(0);
    showState(sCont);
  }

  wrap.querySelector('.fw-retry-btn').addEventListener('click', load);
  wrap.querySelector('.fw-refresh-btn').addEventListener('click', load);

  /* auto-detect HTMX navigation and avoid re-running if already removed */
  document.addEventListener('htmx:afterSettle', function() {
    if (!document.body.contains(wrap)) return;
  });

  load();
})();
</script>
% }

</&>
