<%args>
$HasResults => undef
</%args>
<%init>
my $wid = 'ww' . int(rand(999999));

my $user     = $session{CurrentUser}->UserObj;
my $city     = $user->City    // '';
my $zip      = $user->Zip     // '';
my $country  = $user->Country // '';
my $has_loc  = ($city || $zip) ? 1 : 0;

my $display_loc = join(', ', grep { $_ } ($city, $country));

my %opts;
my @_raw = RT->Config->Get('WeatherWidgetOptions');
%opts = @_raw if @_raw && (@_raw % 2 == 0);
my $temp_unit = lc($opts{TemperatureUnit} // 'celsius');
$temp_unit = 'celsius' unless $temp_unit eq 'fahrenheit';

my $prefs_url = RT->Config->Get('WebPath') . '/Prefs/AboutMe.html';

my $lang_tag = lc( $session{CurrentUser}->LanguageHandle->language_tag // 'en' );
$lang_tag =~ s/_/-/g;

# All per-request data handed to redesign-widgets.js via a data-* attribute on
# the widget root -- no inline <script>. encode_js_json keeps it ascii-safe
# (\uXXXX for loc() utf8 strings); apply_escapes('h') makes it a safe HTML
# attribute value, which dataset decodes back to JSON.
my $enc = \&RT::Extension::Redesign::encode_js_json;
my $ww_config = $enc->({
    city    => $city,
    zip     => $zip,
    country => $country,
    loc     => $display_loc,
    unit    => $temp_unit,
    lang    => $lang_tag,
    labels  => {
        wmo_labels => {
            0  => loc('Clear Sky'),           1  => loc('Mainly Clear'),
            2  => loc('Partly Cloudy'),       3  => loc('Overcast'),
            45 => loc('Fog'),                 48 => loc('Rime Fog'),
            51 => loc('Light Drizzle'),       53 => loc('Moderate Drizzle'),
            55 => loc('Heavy Drizzle'),       56 => loc('Light Freezing Drizzle'),
            57 => loc('Heavy Freezing Drizzle'),
            61 => loc('Light Rain'),          63 => loc('Moderate Rain'),
            65 => loc('Heavy Rain'),          66 => loc('Light Freezing Rain'),
            67 => loc('Heavy Freezing Rain'),
            71 => loc('Light Snow'),          73 => loc('Moderate Snow'),
            75 => loc('Heavy Snow'),          77 => loc('Snow Grains'),
            80 => loc('Light Showers'),       81 => loc('Moderate Showers'),
            82 => loc('Heavy Showers'),       85 => loc('Light Snow Showers'),
            86 => loc('Heavy Snow Showers'),
            95 => loc('Thunderstorm'),        96 => loc('Thunderstorm with Hail'),
            99 => loc('Thunderstorm with Heavy Hail'),
            night   => loc('Clear Night'),    unknown => loc('Unknown'),
        },
        feels_like => loc('Feels like'),
        updated    => loc('Updated'),
        timeout    => loc('Timeout - weather data could not be retrieved.'),
        loc_nf     => loc('Location could not be found.'),
        geo_fail   => loc('Geocoding failed.'),
        wx_fail    => loc('Weather data could not be loaded.'),
        int_err    => loc('Internal error.'),
    },
});
my $ww_attrs = $has_loc
    ? ' data-ww-config="' . $m->interp->apply_escapes( $ww_config, 'h' ) . '"'
    : '';
</%init>
<&|/Widgets/TitleBox, title => loc('Weather'), bodyclass => 'p-0' &>

<div class="ww-wrap" id="<% $wid %>"<% $ww_attrs | n %>>

% if (!$has_loc) {
  <div class="ww-s ww-noloc">
    <span class="ww-big-icon">&#x1F4CD;</span>
    <p><% loc('No location stored in user profile.') | h %></p>
    <a href="<% $prefs_url | h %>" class="btn btn-sm btn-outline-primary">
      <% loc('Edit profile') | h %>
    </a>
  </div>
% } else {

  <div class="ww-s ww-loading">
    <div class="ww-spinner"></div>
    <small><% loc('Loading weather data...') | h %></small>
  </div>

  <div class="ww-s ww-error" hidden>
    <span class="ww-big-icon">&#x26A0;&#xFE0F;</span>
    <p class="ww-err-msg"></p>
    <button class="btn btn-sm btn-outline-secondary ww-retry-btn"><% loc('Retry') | h %></button>
  </div>

  <div class="ww-content" hidden>
    <div class="ww-top">
      <div class="ww-icon"></div>
      <div class="ww-temp"></div>
      <div class="ww-cond"></div>
    </div>
    <div class="ww-row">
      <span class="ww-loc"></span>
      <span class="ww-feels"></span>
      <span class="ww-wind"></span>
      <span class="ww-hum"></span>
    </div>
    <div class="ww-footer">
      <span class="ww-updated"></span>
      <button class="ww-refresh-btn" title="<% loc('Refresh') %>">&#x21BB;</button>
    </div>
  </div>

% }
</div><!-- .ww-wrap -->

<style>
/* ---- WeatherWidget ------------------------------------------ */

.ww-wrap {
  background: #fff;
  border-radius: 0 0 6px 6px;
  display: flex;
  flex-direction: column;
}
[data-bs-theme=dark] .ww-wrap { background: #1a1f2e; }

/* Loading / error / noloc states */
.ww-s {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  gap: 0.3rem;
  padding: 0.6rem 1rem;
  flex: 1;
}

.ww-spinner {
  width: 20px; height: 20px;
  border: 3px solid rgba(0,0,0,0.1);
  border-top-color: var(--bs-primary);
  border-radius: 50%;
  animation: ww-spin 0.75s linear infinite;
}
[data-bs-theme=dark] .ww-spinner { border-color: rgba(255,255,255,0.12); border-top-color: var(--bs-primary); }
@keyframes ww-spin { to { transform: rotate(360deg); } }

.ww-big-icon { font-size: 1.6rem; line-height: 1; }

.ww-noloc p, .ww-error p {
  font-size: 0.82rem; color: #666; margin: 0; max-width: 200px;
}
[data-bs-theme=dark] .ww-noloc p,
[data-bs-theme=dark] .ww-error p { color: #8899b0; }

/* ---- Top: icon + temp left, condition right — single row --- */
.ww-top {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 0.4rem;
  padding: 0.5rem 0.85rem 0.4rem;
  width: 100%;
  box-sizing: border-box;
}

.ww-icon { font-size: 1.9rem; line-height: 1; flex-shrink: 0; }
.ww-temp { font-size: 1.75rem; font-weight: 200; letter-spacing: -0.02em; line-height: 1; color: #222; flex-shrink: 0; }
.ww-cond { flex: 1; text-align: right; font-size: 0.78rem; font-weight: 500; color: #777; }

[data-bs-theme=dark] .ww-temp { color: #dde4f0; }
[data-bs-theme=dark] .ww-cond { color: #8899b0; }

/* ---- Info row: all metadata in one line -------------------- */
.ww-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0 0.15rem;
  padding: 0.3rem 0.85rem;
  border-top: 1px solid rgba(0,0,0,0.07);
  width: 100%;
  font-size: 0.75rem;
  color: #555;
  box-sizing: border-box;
}
[data-bs-theme=dark] .ww-row { border-top-color: rgba(255,255,255,0.07); color: #8899b0; }

.ww-loc { font-weight: 600; color: #333; }
[data-bs-theme=dark] .ww-loc { color: #d0d8e8; }

/* dot separator between each span */
.ww-row span + span::before {
  content: '\00B7';
  margin: 0 0.35rem;
  opacity: 0.35;
}

/* ---- Footer ------------------------------------------------ */
.ww-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0.2rem 0.85rem 0.3rem;
  border-top: 1px solid rgba(0,0,0,0.07);
  width: 100%;
}
[data-bs-theme=dark] .ww-footer { border-top-color: rgba(255,255,255,0.07); }

.ww-updated { font-size: 0.67rem; color: #aaa; }
[data-bs-theme=dark] .ww-updated { color: #5a6880; }

.ww-refresh-btn {
  background: none; border: none; padding: 0;
  cursor: pointer; font-size: 0.95rem; color: #aaa; line-height: 1;
}
.ww-refresh-btn:hover { color: #333; }
[data-bs-theme=dark] .ww-refresh-btn:hover { color: #dde4f0; }

/* ---- KN Theme ---------------------------------------------- */
body.kn .ww-loc     { color: #003B6F; }
body.kn .ww-spinner { border-top-color: #0076BE; }

[data-bs-theme=dark] body.kn .ww-wrap    { background: rgba(0,34,68,0.95); }
[data-bs-theme=dark] body.kn .ww-loc     { color: #5db0e6; }
[data-bs-theme=dark] body.kn .ww-row     { color: rgba(120,175,220,0.75); border-top-color: rgba(0,123,190,0.2); }
[data-bs-theme=dark] body.kn .ww-footer  { border-top-color: rgba(0,123,190,0.2); }
[data-bs-theme=dark] body.kn .ww-spinner { border-top-color: #0076BE; }

/* ---- Terminal Theme ----------------------------------------- */
body.terminal .ww-wrap    { background: #edf5e8; }
body.terminal .ww-loc     { color: #1a5c1a; font-family: 'Courier New', Courier, monospace; }
body.terminal .ww-temp    { font-family: 'Courier New', Courier, monospace; }
body.terminal .ww-row     { color: #3d7a3d; border-top-color: rgba(45,122,45,0.2); }
body.terminal .ww-footer  { border-top-color: rgba(45,122,45,0.2); }
body.terminal .ww-spinner { border-color: rgba(45,122,45,0.15); border-top-color: #2d7a2d; }

[data-bs-theme=dark] body.terminal .ww-wrap    { background: #0a1a0a; }
[data-bs-theme=dark] body.terminal .ww-loc     { color: rgba(26,170,26,0.9); }
[data-bs-theme=dark] body.terminal .ww-row     { color: rgba(26,170,26,0.6); border-top-color: rgba(26,170,26,0.15); }
[data-bs-theme=dark] body.terminal .ww-footer  { border-top-color: rgba(26,170,26,0.15); }
[data-bs-theme=dark] body.terminal .ww-updated { color: rgba(26,170,26,0.4); }
[data-bs-theme=dark] body.terminal .ww-refresh-btn { color: rgba(26,170,26,0.6); }
[data-bs-theme=dark] body.terminal .ww-spinner { border-color: rgba(26,170,26,0.15); border-top-color: rgba(26,170,26,0.85); }
</style>


</&>
