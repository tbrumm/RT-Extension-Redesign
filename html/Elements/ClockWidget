<%args>
$HasResults => undef
</%args>
<%init>
my $wid = 'fc' . int(rand(999999));
my $enc = \&RT::Extension::Redesign::encode_js_json;
# Localised day/month names handed to redesign-widgets.js via a data-* attribute
# (no inline <script>); h-escaped for the attribute, decoded back by dataset.
my $fc_config = $enc->({
    days   => [map { loc($_) } qw(Sunday Monday Tuesday Wednesday Thursday Friday Saturday)],
    months => [map { loc($_) } qw(January February March April May June July August September October November December)],
});
</%init>
<&|/Widgets/TitleBox, title => loc('Clock'), bodyclass => 'p-0' &>

<div class="fc-wrap" id="<% $wid %>" data-fc-config="<% $fc_config %>">
  <div class="fc-clock">

    <div class="fc-grp">
      <div class="fc-pair">
% for my $slot (qw(h0 h1)) {
        <div class="fc-digit" id="<% $wid %>-<% $slot %>">
          <div class="fc-hi"><div class="fc-n">0</div></div>
          <div class="fc-lo"><div class="fc-n">0</div></div>
          <div class="fc-fl"><div class="fc-n">0</div></div>
        </div>
% }
      </div>
      <div class="fc-lbl"><% loc('hrs') %></div>
    </div>

    <div class="fc-dots"><i></i><i></i></div>

    <div class="fc-grp">
      <div class="fc-pair">
% for my $slot (qw(m0 m1)) {
        <div class="fc-digit" id="<% $wid %>-<% $slot %>">
          <div class="fc-hi"><div class="fc-n">0</div></div>
          <div class="fc-lo"><div class="fc-n">0</div></div>
          <div class="fc-fl"><div class="fc-n">0</div></div>
        </div>
% }
      </div>
      <div class="fc-lbl"><% loc('min') %></div>
    </div>


  </div><!-- .fc-clock -->

  <div class="fc-date" id="<% $wid %>-date"></div>
</div><!-- .fc-wrap -->

<style>
/* ---- Flip Clock Widget ---------------------------------------- */

.fc-wrap {
  padding: 1.4rem 1rem 1.1rem;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.9rem;
  background: var(--bs-card-bg);
  border-radius: 0 0 6px 6px;
  width: 100%;
  box-sizing: border-box;
}

.fc-clock {
  display: flex;
  align-items: flex-start;
  gap: 8px;
}

.fc-grp {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
}

.fc-pair {
  display: flex;
  gap: 4px;
}

/* ---- Single digit ------------------------------------------ */
.fc-digit {
  position: relative;
  width: 76px;
  height: 106px;
  border-radius: 9px;
  perspective: 300px;
  box-shadow: 0 4px 16px rgba(0,0,0,0.45), 0 0 0 1px rgba(0,0,0,0.3);
}

/* Top half (static — shows top of CURRENT/NEW digit) */
.fc-hi {
  position: absolute;
  inset: 0 0 50% 0;
  overflow: hidden;
  background: linear-gradient(180deg, #343437 0%, #2c2c2f 100%);
  border-radius: 9px 9px 0 0;
  border-bottom: 1.5px solid rgba(0,0,0,0.6);
  display: flex;
  align-items: flex-start;
}

/* Bottom half (static — shows bottom of CURRENT/NEW digit) */
.fc-lo {
  position: absolute;
  inset: 50% 0 0 0;
  overflow: hidden;
  background: linear-gradient(180deg, #202023 0%, #262629 100%);
  border-radius: 0 0 9px 9px;
  display: flex;
  align-items: flex-end;
}

/* Animated flap — sits over .fc-hi, folds away on change */
.fc-fl {
  position: absolute;
  inset: 0 0 50% 0;
  overflow: hidden;
  background: linear-gradient(180deg, #3c3c3f 0%, #323235 100%);
  border-radius: 9px 9px 0 0;
  transform-origin: bottom center;
  transform: rotateX(0deg);
  z-index: 3;
  backface-visibility: hidden;
  display: flex;
  align-items: flex-start;
}

.fc-digit.flipping .fc-fl {
  animation: fc-fold 0.36s cubic-bezier(0.5, 0, 0.85, 0.3) forwards;
}

@keyframes fc-fold {
  0%   { transform: rotateX(0deg); }
  100% { transform: rotateX(-90deg); }
}

/* ---- Number rendering ---------------------------------------- */
.fc-n {
  width: 100%;
  height: 106px;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: -apple-system, 'Helvetica Neue', Arial, sans-serif;
  font-size: 80px;
  font-weight: 700;
  color: #e8e8ed;
  font-variant-numeric: tabular-nums;
  user-select: none;
  letter-spacing: -0.03em;
}

/* ---- Separator dots ---------------------------------------- */
.fc-dots {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 16px;
  height: 106px;
  padding: 0 2px;
}

.fc-dots i {
  display: block;
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--bs-secondary-color);
  opacity: 0.4;
  font-style: normal;
}

/* ---- Labels ------------------------------------------------ */
.fc-lbl {
  font-size: 0.6rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.11em;
  color: var(--bs-secondary-color);
  opacity: 0.65;
}

/* ---- Date line --------------------------------------------- */
.fc-date {
  font-size: 0.85rem;
  font-weight: 400;
  color: var(--bs-secondary-color);
  letter-spacing: 0.02em;
}
</style>

</&>
