<& /Widgets/TitleBoxStart, title => $title, class => 'user-profile-widget', bodyclass => 'p-0' &>

%# Styles moved to static/css/redesign/redesign-widgets.css (AddStyleSheets).

<div class="profile-banner"></div>

<div class="d-flex align-items-center px-3 pb-2 gap-2">
  <div class="profile-avatar-wrap flex-shrink-0">
    <img src="<% $img_src |h %>"
         class="profile-avatar rounded-circle"
         alt="<% $user->RealName || $user->Name |h %>" />
  </div>
  <div class="overflow-hidden">
    <div class="profile-name text-truncate"><% $user->RealName || $user->Name |h %></div>
%  if ($user->Organization) {
    <div class="profile-org text-body-secondary text-truncate"><% $user->Organization |h %></div>
%  }
  </div>
</div>

<hr class="mx-3 my-0">

<div class="px-3 pt-2 pb-1">

%  if ($user->EmailAddress) {
  <div class="profile-info-row">
    <i class="bi bi-envelope-fill text-primary"></i>
    <a href="mailto:<% $user->EmailAddress |h %>" class="text-break"><% $user->EmailAddress |h %></a>
  </div>
%  }

%  if ($user->WorkPhone) {
  <div class="profile-info-row">
    <i class="bi bi-telephone-fill text-success"></i>
    <div>
      <a href="tel:<% $user->WorkPhone |h %>"><% $user->WorkPhone |h %></a>
      <span class="text-body-secondary ms-1 small"><&|/l&>Work</&></span>
    </div>
  </div>
%  }

%  if ($user->MobilePhone) {
  <div class="profile-info-row">
    <i class="bi bi-phone-fill text-info"></i>
    <div>
      <a href="tel:<% $user->MobilePhone |h %>"><% $user->MobilePhone |h %></a>
      <span class="text-body-secondary ms-1 small"><&|/l&>Mobile</&></span>
    </div>
  </div>
%  }

%  if (@addr_lines) {
  <div class="profile-info-row">
    <i class="bi bi-geo-alt-fill text-danger"></i>
    <address>
%    for my $line (@addr_lines) {
      <% $line |h %><br>
%    }
    </address>
  </div>
%  }

</div>

<div class="profile-edit-bar px-3 py-2 text-center">
  <a href="<% RT->Config->Get('WebPath') %>/Prefs/AboutMe.html"
     class="btn btn-sm btn-outline-primary w-100">
    <i class="bi bi-pencil-square me-1"></i><&|/l&>Edit Profile</&>
  </a>
</div>

<& /Widgets/TitleBoxEnd &>

<%INIT>
my $user  = $session{CurrentUser}->UserObj;
my $title = loc("Welcome [_1]", $user->RealName || $user->Name);

my $img_src = RT->Config->Get('WebPath')
    . ( $session{CurrentUser}->Privileged ? '' : '/SelfService' )
    . '/Helpers/UserImage/'
    . $user->Id . '-'
    . $user->ImageSignature;

my @addr_lines;
push @addr_lines, $user->Address1 if $user->Address1;
push @addr_lines, $user->Address2 if $user->Address2;
my $city_line = join(' ', grep { length $_ } $user->Zip // '', $user->City // '');
push @addr_lines, $city_line      if $city_line;
push @addr_lines, $user->Country  if $user->Country;
</%INIT>
