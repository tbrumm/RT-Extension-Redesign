<& /Widgets/TitleBoxStart, title => loc('Quick search'), class => 'articles-quicksearch' &>
<div class="px-2 pt-2 pb-1">
  <form method="get" action="<%RT->Config->Get('WebPath')%>/Articles/Article/Search.html" class="d-flex gap-2">
    <input type="text" name="q" class="form-control form-control-sm" placeholder="<% loc('Search articles...') |h %>" autocomplete="off" />
    <button type="submit" class="btn btn-sm btn-primary flex-shrink-0"><% loc('Search') %></button>
  </form>
</div>
% if ($classes->Count) {
<div class="px-2 pt-1 pb-1">
  <div class="small text-body-secondary mb-1"><% loc('Browse by class:') %></div>
  <div class="d-flex flex-wrap gap-1 pb-1">
%   $classes->GotoFirstItem;
%   while (my $class = $classes->Next) {
    <a href="<%RT->Config->Get('WebPath')%>/Articles/Article/Search.html?Class=<%$class->id%>&Parent=0&HideOptions=1"
       class="badge text-bg-secondary text-decoration-none"><%$class->Name%></a>
%   }
  </div>
</div>
% }
<& /Widgets/TitleBoxEnd &>
<%init>
my $classes = RT::Classes->new($session{'CurrentUser'});
$classes->LimitToEnabled;
$classes->CountAll;
</%init>
