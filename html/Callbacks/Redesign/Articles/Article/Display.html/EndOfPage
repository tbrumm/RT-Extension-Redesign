<%ARGS>
$ArticleObj => undef
</%ARGS>
% return unless $ArticleObj && $ArticleObj->id;
% my $id  = $ArticleObj->id;
% my $url = RT->Config->Get('WebPath') . '/Articles/Article/Display.html?id=' . $id;
%# redesign-ticket.js reads this hidden marker and records the article into the
%# rt_recent_articles localStorage list -- no inline <script>. Values are
%# h-escaped (Mason default) for the attributes and decoded back via dataset.
<span class="rt-article-recorder d-none" data-ra-id="<% $id %>" data-ra-name="<% $ArticleObj->Name %>" data-ra-class="<% $ArticleObj->ClassObj->Name %>" data-ra-url="<% $url %>"></span>
