<%ARGS>
$Record => undef
$Column => undef
$Out    => undef
</%ARGS>
<%INIT>
# Render a ticket's Priority cell as a severity-coloured badge showing label /
# number / both per the user's RedesignPriorityDisplay preference. Hooked here
# (per-cell, per-request) rather than in RT__Ticket/ColumnMap/Once because core
# re-sets $COLUMN_MAP->{Priority}{value} on every request while that Once
# callback fires only once per worker. Colour comes from the ticket's position
# in its queue's %PriorityAsString mapping (not label spelling), so it adapts to
# renamed/added levels and is independent of the global $EnablePriorityAsString.
return unless $Record && ref $Record && $Record->isa('RT::Ticket');
return unless $Out && ref $Out eq 'ARRAY';
# Locate the __Priority__ token(s) in this column's format. We replace only that
# one cell piece with our badge, keeping any surrounding literal markup -- a
# saved search may wrap it (e.g. <small>__Priority__</small>) or combine it with
# other fields, in which case 'output' holds several tokens, not just one.
# InitialPriority/FinalPriority are left untouched (exact token match). Core
# builds @$Out with one element per output token in order, so the indices align.
return unless $Column && ref $Column->{output} eq 'ARRAY';
my @out_tokens = @{ $Column->{output} };
my @prio_idx = grep { defined $out_tokens[$_] && $out_tokens[$_] eq '__Priority__' }
                    0 .. $#out_tokens;
return unless @prio_idx;

use RT::Extension::Redesign;

my $num = $Record->Priority;
return unless defined $num && length $num;

my $mode = RT->Config->Get(
    'RedesignPriorityDisplay', $session{'CurrentUser'}->UserObj ) || 'text';
$mode = 'text' unless $mode eq 'number' || $mode eq 'both';

my %colors;
{
    my @raw = RT->Config->Get('RedesignPriorityColors');
    %colors = @raw if @raw && @raw % 2 == 0;
}

my $map  = $Record->GetPriorityAsStringMapping;
my $info = $map ? RT::Extension::Redesign::PriorityInfo( $map, $num ) : undef;

my $badge;
# No mapping (queue set to 0 in %PriorityAsString, or unconfigured) or a value
# below the lowest threshold: show the number in a neutral badge.
unless ($info) {
    my $n = $m->interp->apply_escapes( $num, 'h' );
    $badge = qq{<span class="badge" style="background-color:#6c757d;color:#fff">$n</span>};
}
else {
    my $label = $info->{label};
    my $lbl   = loc($label);
    my $text  = $mode eq 'number' ? $num
              : $mode eq 'both'   ? "$lbl ($num)"
              :                     $lbl;

    my $bg = $colors{$label}
          // RT::Extension::Redesign::PriorityAutoColor( $info->{index}, $info->{count} );
    my $fg = RT::Extension::Redesign::ContrastText($bg);

    my $etext = $m->interp->apply_escapes( $text, 'h' );
    my $ebg   = $m->interp->apply_escapes( $bg,   'h' );
    my $efg   = $m->interp->apply_escapes( $fg,   'h' );
    $badge = qq{<span class="badge" style="background-color:$ebg;color:$efg">$etext</span>};
}

$Out->[$_] = $badge for grep { $_ <= $#$Out } @prio_idx;
</%INIT>
