<%init>
use POSIX qw(strftime);

# Maintenance/welcome banner configured under /Admin/Global/LoginBanner.html.
# Stored as the MaintenanceBannerData System attribute; rendered here above the
# login form. When inactive we emit nothing, so /Elements/Login falls back to
# its promo grid.
my $attr = RT->System->FirstAttribute('MaintenanceBannerData');
my $data = $attr ? $attr->Content : {};
$data = {} unless ref $data eq 'HASH';

# Mirror the admin page's legacy fallback to the old boolean-only attribute.
unless ( exists $data->{enabled} ) {
    my $old = RT->System->FirstAttribute('MaintenanceBannerEnabled');
    $data->{enabled} = $old ? $old->Content : 1;
}

my $today = strftime( '%Y-%m-%d', localtime );
my $show  = RT::Extension::Redesign::banner_is_active( $data, $today );

my $defaults = RT::Extension::Redesign::banner_defaults();
my $headline   = ( defined $data->{headline}   && length $data->{headline}   ) ? $data->{headline}   : $defaults->{headline};
# The headline editor (CKEditor) wraps its value in <p>…</p>; unwrap it so the
# headline stays inline inside the banner's <h2>.
$headline = RT::Extension::Redesign::strip_outer_paragraph($headline);
my $content_de = ( defined $data->{content_de} && length $data->{content_de} ) ? $data->{content_de} : $defaults->{content_de};
my $content_en = ( defined $data->{content_en} && length $data->{content_en} ) ? $data->{content_en} : $defaults->{content_en};

# Banner type: 'info' (blue, default) or 'warning' (red). Styling lives in
# redesign.css (.rd-login-banner / .rd-login-banner--warning), shared with the
# admin preview so both render identically.
my $is_warning = ( ($data->{type} // 'info') eq 'warning' ) ? 1 : 0;
</%init>
% if ($show) {
<div class="rd-login-banner<% $is_warning ? ' rd-login-banner--warning' : '' %>">
  <div class="rd-login-banner-header">
    <span class="rd-login-banner-header-icon"><% $is_warning ? '&#9888;' : '&#10003;' |n %></span>
%# Headline is HTML entered by a SuperUser on the admin page ("HTML allowed").
    <h2><% $headline |n %></h2>
  </div>
  <div class="rd-login-banner-body">
    <div class="rd-login-banner-cell rd-login-banner-cell-de">
      <h3>&#127465;&#127466; Deutsch</h3>
%# Body content is HTML entered by a SuperUser on the admin page.
      <% $content_de |n %>
    </div>
    <div class="rd-login-banner-cell">
      <h3>&#127468;&#127463; English</h3>
      <% $content_en |n %>
    </div>
  </div>
</div>
% }
