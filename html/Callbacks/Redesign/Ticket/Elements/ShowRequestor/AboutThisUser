<%args>
$requestor
</%args>
<%init>
# Performance-Fix: CachedGroupMembers-Reverse-Lookup statt 6-JOIN Forward-Scan
# ueber alle 141K Assets. Reverse-Query: ~12ms vs. ~800ms Forward.
my $dbh = RT->DatabaseHandle->dbh;
my $uid = $requestor->Id;

# `Groups` is a reserved word in MySQL 8; quote_identifier emits the right
# identifier quoting for whichever DB driver is active (backticks on MySQL,
# double quotes on PostgreSQL/Oracle/SQLite).
my $groups = $dbh->quote_identifier('Groups');

my $ids = eval {
    $dbh->selectcol_arrayref(qq{
        SELECT DISTINCT g.Instance
        FROM CachedGroupMembers cgm
        JOIN $groups g
          ON g.id = cgm.GroupId
         AND g.Domain = 'RT::Asset-Role'
         AND g.Name IN ('HeldBy','Contact','Owner')
        JOIN Assets a ON a.id = g.Instance AND a.Status != 'deleted'
        WHERE cgm.MemberId = ? AND cgm.Disabled = 0
        LIMIT 20
    }, undef, $uid);
};
RT::Logger->error("Redesign AboutThisUser asset lookup: $@") if $@;

return unless $ids && @$ids;

my $assets = RT::Assets->new($session{CurrentUser});
$assets->Limit(
    FIELD    => 'id',
    OPERATOR => 'IN',
    VALUE    => $ids,
);
$assets->OrderByCols({ FIELD => 'Name', ORDER => 'ASC' });
</%init>
<div class="more-about-requestor-assets">
<&| /Widgets/TitleBox, title => loc('Assigned Assets') &>
  <& /Elements/CollectionList,
      Collection   => $assets,
      Format       => q['<b><a href="__WebHomePath__/Asset/Display.html?id=__id__">__id__</a></b>/TITLE:#','<b><a href="__WebHomePath__/Asset/Display.html?id=__id__">__Name__</a></b>/TITLE:Name',Description],
      AllowSorting => 0,
  &>
</&>
</div>
