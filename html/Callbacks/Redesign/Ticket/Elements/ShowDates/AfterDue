<%ARGS>
$TicketObj => undef
</%ARGS>
<%INIT>
return unless $TicketObj;
my $due = $TicketObj->DueObj;
return unless $due && $due->IsSet
    && $TicketObj->QueueObj->IsActiveStatus($TicketObj->Status);
my $diff  = $due->Diff;
my $class = $diff <= 0     ? 'due-overdue'
          : $diff <= 86400 ? 'due-soon'
          :                  'due-ok';
</%INIT>
%# redesign-ticket.js reads this hidden marker, applies the class to the core
%# due-date value and drops the marker -- no inline <script>.
<span class="rt-due-flag d-none" data-due-class="<% $class %>"></span>
