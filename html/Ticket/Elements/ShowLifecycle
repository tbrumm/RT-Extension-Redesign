<%args>
$TicketObj
$HTMXLoad => 0
</%args>
<%init>
return unless $TicketObj && $TicketObj->id;

my $queue = $TicketObj->QueueObj;
my $lc    = $queue->LifecycleObj;
return unless $lc;

# ── lifecycle data ───────────────────────────────────────────────────────────
my @initial  = $lc->Initial;
my @active   = $lc->Active;
my @inactive = $lc->Inactive;
my @all      = $lc->Valid;
my $current  = $TicketObj->Status;

my %trans;
for my $from (@all) {
    my @to = $lc->Transitions($from);
    $trans{$from} = \@to if @to;
}

my $total = scalar @all;

# ── JSON for the adaptive JS renderer ───────────────────────────────────────
require JSON::PP;
my $lc_json = JSON::PP->new->utf8->encode( {
    initial     => \@initial,
    active      => \@active,
    inactive    => \@inactive,
    transitions => \%trans,
    current     => $current,
    name        => $lc->Name,
    queue       => $queue->Name,
    # Localised labels for redesign-ticket.js (it reads data-lc, no inline JS).
    labels      => {
        initial  => loc('Initial'),
        active   => loc('Active'),
        inactive => loc('Inactive'),
        complex  => loc('Complex lifecycle (%1 statuses) — showing transitions from/to current status only.', '%1'),
    },
} );

# ── static SVG layout (always-works fallback, NW=120) ───────────────────────
my $NW   = 120;
my $NH   = 30;
my $RG   = 8;
my $CG   = 72;
my $PAD  = 16;
my $TPAD = 38;

my $ACT_COLS  = $total > 16 ? 3 : $total > 8 ? 2 : 1;
my $ACT_COL_W = $NW + 16;

my $xIni = $PAD;
my $xAct = $xIni + $NW + $CG;
my $xIna = $xAct + $ACT_COLS * $ACT_COL_W - 16 + $CG;

my %nodes;
for my $i ( 0 .. $#initial ) {
    $nodes{ $initial[$i] } = { x => $xIni, y => $TPAD + $i * ($NH + $RG), type => 'initial' };
}
for my $i ( 0 .. $#active ) {
    my $c = $i % $ACT_COLS;
    my $r = int( $i / $ACT_COLS );
    $nodes{ $active[$i] } = { x => $xAct + $c * $ACT_COL_W, y => $TPAD + $r * ($NH + $RG), type => 'active' };
}
for my $i ( 0 .. $#inactive ) {
    $nodes{ $inactive[$i] } = { x => $xIna, y => $TPAD + $i * ($NH + $RG), type => 'inactive' };
}

my $svgW = $PAD; my $svgH = $PAD;
for my $n ( values %nodes ) {
    my $r = $n->{x} + $NW + $PAD; my $b = $n->{y} + $NH + $PAD;
    $svgW = $r if $r > $svgW; $svgH = $b if $b > $svgH;
}

# Arrow helper — anonymous sub to properly close over $NW/$NH
my $_ap = sub {
    my ( $src, $dst, $bo ) = @_;
    if ( abs( $src->{x} - $dst->{x} ) < 5 ) {
        my ($sx,$sy,$dx,$dy) = ($src->{x}+$NW, $src->{y}+$NH/2, $dst->{x}+$NW, $dst->{y}+$NH/2);
        my $mx = $sx + 30 + abs($sy-$dy)*0.25;
        return sprintf 'M%.1f,%.1f C%.1f,%.1f %.1f,%.1f %.1f,%.1f',$sx,$sy,$mx,$sy,$mx,$dy,$dx,$dy;
    }
    if ( $src->{x} < $dst->{x} - 5 ) {
        my ($sx,$sy,$dx,$dy) = ($src->{x}+$NW,$src->{y}+$NH/2,$dst->{x},$dst->{y}+$NH/2);
        my $mx = ($sx+$dx)/2;
        return sprintf 'M%.1f,%.1f C%.1f,%.1f %.1f,%.1f %.1f,%.1f',$sx,$sy,$mx,$sy,$mx,$dy,$dx,$dy;
    }
    my ($sx,$sy,$dx,$dy) = ($src->{x},$src->{y}+$NH/2,$dst->{x}+$NW,$dst->{y}+$NH/2);
    my $ay = 6 + ($bo||0)*10;
    return sprintf 'M%.1f,%.1f C%.1f,%.1f %.1f,%.1f %.1f,%.1f',$sx,$sy,$sx,$ay,$dx,$ay,$dx,$dy;
};

my $SIMPLE = ( $total <= 20 );
my %trans_show = $SIMPLE ? %trans : ();
unless ($SIMPLE) {
    $trans_show{$current} = $trans{$current} if $trans{$current};
    for my $f ( keys %trans ) {
        if ( grep { $_ eq $current } @{ $trans{$f} } ) { $trans_show{$f} //= $trans{$f}; }
    }
}

my @arrows; my $bc = 0;
for my $from ( sort keys %trans_show ) {
    next unless $nodes{$from};
    for my $to ( @{ $trans_show{$from} } ) {
        next unless $nodes{$to}; next if $from eq $to;
        my $ic  = ($from eq $current || $to eq $current);
        my $ib  = $nodes{$from}{x} >= $nodes{$to}{x} - 5 && abs($nodes{$from}{x} - $nodes{$to}{x}) >= 5;
        my $bo  = $ib ? $bc++ : 0;
        push @arrows, { d => $_ap->($nodes{$from},$nodes{$to},$bo), cur => $ic };
    }
}

my $_tr = sub { my($s,$m)=@_; length($s)<=$m ? $s : substr($s,0,$m-3).'...' };

my $wid = 'lw-' . $TicketObj->id . '-' . $queue->id;
</%init>

<&| /Widgets/TitleBox,
    title              => loc('Lifecycle') . ': ' . $lc->Name,
    class              => 'lw-titlebox',
    content_body_class => 'p-2',
&>

<div id="<% $wid %>" data-lc="<% $lc_json |h %>">
  <div class="lw-legend small text-muted">
    <span><span class="lw-dot lw-dot-i"></span><% loc('Initial') %></span>
    <span><span class="lw-dot lw-dot-a"></span><% loc('Active') %></span>
    <span><span class="lw-dot lw-dot-n"></span><% loc('Inactive') %></span>
    <span><span class="lw-dot lw-dot-c"></span><% loc('Current') %></span>
  </div>
  <div class="lw-svg-scroll">
    <svg id="<% $wid %>-svg" class="lw-svg"
         viewBox="0 0 <% $svgW %> <% $svgH %>"
         style="width:100%;max-width:<% $svgW %>px"
         xmlns="http://www.w3.org/2000/svg">

      <!-- static fallback content – JS will replace this -->
      <defs>
        <marker id="<% $wid %>-mk" markerWidth="8" markerHeight="6"
                refX="7" refY="3" orient="auto">
          <polygon points="0 0,8 3,0 6" class="lw-mkarr"/></marker>
        <marker id="<% $wid %>-mk-cur" markerWidth="8" markerHeight="6"
                refX="7" refY="3" orient="auto">
          <polygon points="0 0,8 3,0 6" class="lw-mkarr-cur"/></marker>
      </defs>
% if (@initial) {
      <text x="<% $xIni+$NW/2 %>" y="<% $TPAD-8 %>" text-anchor="middle" font-size="10" class="lw-col-label"><% loc('Initial') %></text>
% }
% if (@active) {
      <text x="<% $xAct+($ACT_COLS*$ACT_COL_W-16)/2 %>" y="<% $TPAD-8 %>" text-anchor="middle" font-size="10" class="lw-col-label"><% loc('Active') %></text>
% }
% if (@inactive) {
      <text x="<% $xIna+$NW/2 %>" y="<% $TPAD-8 %>" text-anchor="middle" font-size="10" class="lw-col-label"><% loc('Inactive') %></text>
% }
% for my $a (@arrows) {
      <path d="<% $a->{d} %>" fill="none"
            class="<% $a->{cur} ? 'lw-arr lw-arr-cur' : 'lw-arr' %>"
            marker-end="url(#<% $wid %><% $a->{cur} ? '-mk-cur' : '-mk' %>)"/>
% }
% for my $s ( sort keys %nodes ) {
%   my $n=$nodes{$s}; my $ic=($s eq $current);
      <g class="lw-node lw-<% $n->{type} %><% $ic?' lw-current':'' %>">
        <title><% $s|h %><% $ic?' (current)':'' %></title>
        <rect x="<% $n->{x} %>" y="<% $n->{y} %>" width="<% $NW %>" height="<% $NH %>"
              rx="4" ry="4" class="lw-rect"/>
        <text x="<% $n->{x}+$NW/2 %>" y="<% $n->{y}+$NH/2 %>"
              text-anchor="middle" dominant-baseline="central"
              font-size="11" class="lw-lbl"><% $_tr->($s,14)|h %></text>
      </g>
% }
    </svg>
  </div>
  <div id="<% $wid %>-info" class="small text-muted mt-1"
       style="display:<% $SIMPLE?'none':'block' %>"><% $SIMPLE?'':loc('Complex lifecycle (%1 statuses) — showing transitions from/to current status only.', $total) %></div>
</div>

</&>
