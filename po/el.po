msgid "Statistics updated twice daily. Last update: %1"
msgstr "Τα στατιστικά ενημερώνονται δύο φορές την ημέρα. Τελευταία ενημέρωση: %1"

msgid "Successfully logged out"
msgstr "Αποσυνδεθήκατε επιτυχώς"

msgid "Goodbye, %1. See you next time!"
msgstr "Αντίο, %1. Τα λέμε!"

msgid "Your session has been securely closed."
msgstr "Η συνεδρία σας έκλεισε με ασφάλεια."

msgid "Redirecting to login in %1 seconds."
msgstr "Ανακατεύθυνση στη σύνδεση σε %1 δευτερόλεπτα."

msgid "Securely logged out"
msgstr "Ασφαλής αποσύνδεση"

msgid "All session data has been securely deleted from this device."
msgstr "Όλα τα δεδομένα συνεδρίας διαγράφηκαν με ασφάλεια από αυτή τη συσκευή."

msgid "Email still active"
msgstr "Το email είναι ακόμα ενεργό"

msgid "New tickets can be submitted at any time by sending an email."
msgstr "Νέα αιτήματα μπορούν να υποβληθούν οποτεδήποτε μέσω email."

msgid "Your tickets are safe"
msgstr "Τα αιτήματά σας είναι ασφαλή"

msgid "Your open tickets remain saved and continue to be processed."
msgstr "Τα ανοιχτά αιτήματά σας παραμένουν αποθηκευμένα και συνεχίζουν να επεξεργάζονται."

msgid "Want to sign in again?"
msgstr "Θέλετε να συνδεθείτε ξανά;"


